{
  "name": "@shapeshift-labs/frontier-lang-jsx",
  "version": "0.1.0",
  "description": "Runtime-neutral JSX semantic merge evidence for Frontier Lang.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "bench"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "npm run build && node test/smoke.mjs",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit -p test/tsconfig.json",
    "fuzz": "npm run build && node fuzz/smoke.mjs",
    "bench": "npm run build && node bench/smoke.mjs",
    "prepare": "npm run build",
    "prepack": "npm run lint && npm test && npm run typecheck",
    "pack:dry": "npm pack --dry-run",
    "lint": "node scripts/lint.mjs"
  },
  "keywords": [
    "frontier",
    "semantic-merge",
    "jsx",
    "tsx"
  ],
  "author": "ShapeShift Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/siliconjungle/-shapeshift-labs-frontier-lang-jsx.git"
  },
  "bugs": {
    "url": "https://github.com/siliconjungle/-shapeshift-labs-frontier-lang-jsx/issues"
  },
  "homepage": "https://github.com/siliconjungle/-shapeshift-labs-frontier-lang-jsx#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "@shapeshift-labs/frontier-lang-kernel": "0.3.12"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
